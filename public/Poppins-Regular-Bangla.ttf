-1'
    } catch (e) {
      console.error("Could not load font", e);
      // Don't set fontLoaded so it can be retried, but prevent crashing
      return null;
    }
  }

 const handleDownloadPdf = async () => {
    const element = receiptRef.current;
    if (!element) return;

    setIsDownloading(true);

    try {
        const font = await loadFont();

        const canvas = await html2canvas(element, {
            scale: 2,
            backgroundColor: '#ffffff',
            useCORS: true,
        });
        
        const imgData = canvas.toDataURL('image/jpeg', 0.9);
        const pdf = new jsPDF('p', 'mm', 'a4');

        if (font) {
            pdf.addFileToVFS("Poppins-Regular-Bangla.ttf", font);
            pdf.addFont("Poppins-Regular-Bangla.ttf", "PoppinsBangla", "normal");
            pdf.setFont("PoppinsBangla");
        }
        
        const pdfWidth = pdf.internal.pageSize.getWidth();
        const pdfHeight = pdf.internal.pageSize.getHeight();
        
        const imgProps = pdf.getImageProperties(imgData);
        const imgWidth = pdfWidth - 20; // with margin
        const imgHeight = (imgProps.height * imgWidth) / imgProps.width;
        
        const x = (pdfWidth - imgWidth) / 2;
        const y = (pdfHeight > imgHeight) ? (pdfHeight - imgHeight) / 2 : 10;
        
        pdf.addImage(imgData, 'JPEG', x, y, imgWidth, imgHeight);
        
        const dateText = new Date(payment.date).toLocaleDateString(language === 'bn' ? 'bn-BD' : 'en-US');
        
        // --- Watermark Logic ---
        const GState = (pdf as any).GState;
        if (GState) {
          pdf.setGState(new GState({opacity: 0.1}));
        } else {
          console.warn("jsPDF GState not available. Watermark may not have opacity.");
        }
        
        pdf.setFontSize(22);
        pdf.setTextColor(0, 0, 0);

        const watermarkTexts = ['বন্ধন১৭', payment.name, payment.transactionId, dateText];
        let textIndex = 0;

        for (let i = -pdfHeight; i < pdfHeight * 1.5; i += 40) {
          for (let j = -pdfWidth; j < pdfWidth * 1.5; j+= 100) {
            const watermarkText = watermarkTexts[textIndex % watermarkTexts.length];
            pdf.text(watermarkText, j, i, { angle: -45 });
            textIndex++;
          }
        }
        
        if (GState) {
          pdf.setGState(new GState({opacity: 1}));
        }

        pdf.save(`receipt-${payment.transactionId}.pdf`);
    } catch (error) {
        console.error("Error generating PDF:", error);
    } finally {
        setIsDownloading(false);
    }
};


  const statusText = text.statusMap[payment.status as keyof typeof text.statusMap];
  const dateText = new Date(payment.date).toLocaleDateString(language === 'bn' ? 'bn-BD' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' });


  return (
    <>
      <Button variant="outline" size="sm" onClick={handleDownloadPdf} disabled={disabled || isDownloading}>
        {isDownloading ? (
            <>
                <Loader2 className="mr-2 h-4 w-4 animate-spin" />
                {text.downloading}
            </>
        ) : (
            <>
                <Download className="mr-2 h-4 w-4" />
                {text.download}
            </>
        )}
      </Button>

       <div
        className="fixed -z-10"
        style={{
            position: 'absolute',
            left: '-9999px',
            top: 'auto',
            width: '800px',
            height: 'auto',
        }}
        aria-hidden="true"
        >
         <div
            ref={receiptRef}
            className={`${poppins.className} p-4`}
            style={{
                backgroundColor: 'white',
                color: 'black',
            }}
            >
              <Card className="border-2 border-dashed shadow-none bg-white rounded-lg">
                  <CardHeader className="text-center space-y-2">
                      <div className="flex justify-center items-center gap-2">
                          <TakaSymbolIcon className="h-10 w-10 text-black" />
                          <CardTitle className="text-3xl font-bold text-black">{text.title}</CardTitle>
                      </div>
                      <CardDescription className="text-sm text-gray-600">{text.description}</CardDescription>
                  </CardHeader>
                  <CardContent className="space-y-4 px-8">
                      <Separator className="bg-gray-300" />
                      <InfoRow label={text.memberName} value={payment.name} />
                      <InfoRow label={text.memberId} value={payment.memberId} />
                      <Separator className="bg-gray-300"/>
                      <InfoRow label={text.transactionDate} value={dateText} />
                      <InfoRow label={text.transactionId} value={payment.transactionId} />
                      <InfoRow label={text.transactionStatus} value={statusText} />
                      <InfoRow label={text.approvedBy} value={payment.approvedBy} />
                      <Separator className="bg-gray-300"/>
                      <div className="flex justify-between items-center py-2 text-lg font-bold text-black">
                          <span>{text.totalAmount}</span>
                          <span>৳{payment.amount.toLocaleString(language === 'bn' ? 'bn-BD' : 'en-US')}</span>
                      </div>
                      <Separator className="bg-gray-300"/>
                  </CardContent>
                  <CardFooter className="flex-col items-center text-center text-xs text-gray-500 space-y-2 pt-4">
                      <p>{text.footerNote}</p>
                      <p>{text.copyright}</p>
                  </CardFooter>
              </Card>
          </div>
       </div>
    </>
  );
}
